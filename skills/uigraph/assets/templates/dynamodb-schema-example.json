{
  "name": "events",
  "description": "Event store for analytics",
  "dialect": "dynamodb",
  "primaryKey": {
    "partitionKey": "eventId",
    "partitionKeyType": "S",
    "sortKey": "timestamp",
    "sortKeyType": "N"
  },
  "globalSecondaryIndexes": [
    {
      "id": "a1b2c3d4-e5f6-4a7b-8c9d-0e1f2a3b4c5d",
      "name": "userId-index",
      "partitionKey": "userId",
      "partitionKeyType": "S",
      "sortKey": "timestamp",
      "sortKeyType": "N"
    }
  ],
  "attributes": [
    {
      "id": "b2c3d4e5-f6a7-4b8c-9d0e-1f2a3b4c5d6e",
      "name": "eventId",
      "type": "string",
      "required": true,
      "notes": "Unique event identifier"
    },
    {
      "id": "c3d4e5f6-a7b8-4c9d-0e1f-2a3b4c5d6e7f",
      "name": "userId",
      "type": "string",
      "required": true,
      "notes": "User who triggered the event"
    },
    {
      "id": "d4e5f6a7-b8c9-4d0e-1f2a-3b4c5d6e7f8a",
      "name": "timestamp",
      "type": "number",
      "required": true,
      "notes": "Unix timestamp in milliseconds"
    },
    {
      "id": "e5f6a7b8-c9d0-4e1f-2a3b-4c5d6e7f8a9b",
      "name": "eventType",
      "type": "string",
      "required": true,
      "notes": "Type of event"
    },
    {
      "id": "f6a7b8c9-d0e1-4f2a-3b4c-5d6e7f8a9b0c",
      "name": "payload",
      "type": "object",
      "required": true,
      "notes": "Event payload",
      "fields": [
        {
          "id": "a7b8c9d0-e1f2-4a3b-4c5d-6e7f8a9b0c1d",
          "name": "pageUrl",
          "type": "string",
          "required": false
        },
        {
          "id": "b8c9d0e1-f2a3-4b4c-5d6e-7f8a9b0c1d2e",
          "name": "metadata",
          "type": "object",
          "required": false,
          "fields": [
            {
              "id": "c9d0e1f2-a3b4-4c5d-6e7f-8a9b0c1d2e3f",
              "name": "device",
              "type": "string",
              "required": false
            },
            {
              "id": "d0e1f2a3-b4c5-4d6e-7f8a-9b0c1d2e3f4a",
              "name": "browser",
              "type": "string",
              "required": false
            }
          ]
        }
      ]
    }
  ]
}
